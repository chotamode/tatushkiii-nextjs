# OpnForm (self-hosted booking form embedded on-site)
# Build-time vars in Coolify — rebuild after changing them.
NEXT_PUBLIC_OPNFORM_BASE_URL=https://opnform.tzhk.dev
NEXT_PUBLIC_OPNFORM_FORM_SLUG=contact-form-imvqis

# Shared secret guarding POST /api/revalidate (Payload webhook → cache refresh).
REVALIDATE_SECRET=change-me

# Настройки сайта
NEXT_PUBLIC_SITE_URL=http://128.140.45.14

# Контакты (опционально - можно хардкодить в коде)
# NEXT_PUBLIC_TELEGRAM=@your_telegram
# NEXT_PUBLIC_WHATSAPP=+7XXXXXXXXXX
# NEXT_PUBLIC_EMAIL=your@email.com

# Google Analytics (опционально)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Yandex Metrika (опционально)
# NEXT_PUBLIC_YM_ID=XXXXXXXX

# --- Content / CMS (Payload) -------------------------------------------------
# The site reads portfolio content from a Payload CMS on the server (ISR).
# Leave CMS_URL blank to run on local fallback data (lib/content/portfolio.seed.ts)
# — the site works fully without a CMS. Swapping CMS = rewrite lib/content/portfolio.ts.
# These are server-only (not NEXT_PUBLIC); the CMS is fetched server-side.
CMS_URL=
# Hostname that CMS-uploaded media is actually served from, if different from
# CMS_URL (e.g. Payload's S3/R2 storage adapter returns absolute URLs on the
# bucket's public domain, not proxied through CMS_URL). Required for next/image
# to be allowed to optimize those images — omit only if media truly lives under
# CMS_URL.
CMS_MEDIA_URL=
# Pick the tenant by slug (resolved via the CMS) or by id directly. Set one.
CMS_TENANT_SLUG=tatushka
# CMS_TENANT_ID=
# ISR cache window (seconds) for CMS fetches.
CMS_REVALIDATE_SECONDS=60
