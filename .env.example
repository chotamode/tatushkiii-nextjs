# OpnForm (self-hosted booking form embedded on-site)
# Build-time vars in Coolify — rebuild after changing them.
NEXT_PUBLIC_OPNFORM_BASE_URL=https://opnform.tzhk.dev
NEXT_PUBLIC_OPNFORM_FORM_SLUG=contact-form-imvqis

# Directus headless CMS (client-editable content).
# Leave DIRECTUS_URL empty to fall back to the bundled locales/*.json content.
DIRECTUS_URL=https://cms.doomp.ink
# Read-only static token (or leave empty if the collections are public-readable).
DIRECTUS_TOKEN=
# Shared secret guarding POST /api/revalidate (Directus webhook → cache refresh).
REVALIDATE_SECRET=change-me

# Admin token — used ONLY by scripts/seed-directus.ts for the one-time import.
DIRECTUS_ADMIN_TOKEN=

# Настройки сайта
NEXT_PUBLIC_SITE_URL=http://128.140.45.14

# Контакты (опционально - можно хардкодить в коде)
# NEXT_PUBLIC_TELEGRAM=@your_telegram
# NEXT_PUBLIC_WHATSAPP=+7XXXXXXXXXX
# NEXT_PUBLIC_EMAIL=your@email.com

# Google Analytics (опционально)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Yandex Metrika (опционально)
# NEXT_PUBLIC_YM_ID=XXXXXXXX
